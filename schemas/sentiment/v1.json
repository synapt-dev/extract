{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synapt.dev/schemas/sentiment/v1.json",
  "title": "SynaptSentiment",
  "description": "Structured sentiment analysis with valence, intensity, and confidence.",
  "type": "object",
  "properties": {
    "version": {
      "const": "1",
      "description": "Sub-schema version."
    },
    "valence": {
      "type": "string",
      "enum": ["positive", "negative", "neutral", "mixed"],
      "description": "Overall sentiment direction."
    },
    "intensity": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Strength of sentiment (0.0 = barely detectable, 1.0 = strongest)."
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence in the sentiment assessment (0.0 to 1.0)."
    }
  },
  "required": ["valence"],
  "additionalProperties": false
}
