{
  "name": "@synapt-dev/extract",
  "version": "0.2.0",
  "description": "SynaptExtraction IL v1 -- schema, validation, and finalization",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "src",
    "prompts"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "test -d ../../prompts && cp -r ../../prompts ./prompts || true"
  },
  "keywords": [
    "synapt",
    "extraction",
    "schema",
    "intermediate-language"
  ],
  "author": "Layne Penney",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/synapt-dev/extract.git",
    "directory": "packages/ts"
  },
  "homepage": "https://synapt.dev",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/ui": "^4.1.5",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5"
  }
}
